// ═══════════════════════════════════════════════════════════════════════════
// PHASE 1 — SIGNAL LOGIC (plain English)
// ═══════════════════════════════════════════════════════════════════════════
// Primary trend: fast EMA vs slow EMA on the chart timeframe.
//   • Bullish signal: fast crosses ABOVE slow (edge-triggered on that bar).
//   • Bearish signal: fast crosses BELOW slow (edge-triggered on that bar).
// Entries (indicator): a Buy marker = bullish crossover AND all enabled filters pass.
//                     a Sell marker = bearish crossover AND all enabled filters pass.
// Exits: this is an indicator, not a broker strategy — the opposite crossover is the
//        trend-flip cue; you manage position size and stops outside the script.
// Optional HTF: when enabled, the higher-timeframe EMA alignment must agree with the
//        signal direction (bull cross requires HTF fast > slow, bear the inverse).
// ═══════════════════════════════════════════════════════════════════════════
// PHASES 2–6: EMA core, markers, ADX + optional volume filters, inputs, alerts, testing notes at bottom.

//@version=5
indicator("NQ Trend Following (Base)", shorttitle="Trend Base", overlay=true,
     max_lines_count=50, max_labels_count=50,
     max_boxes_count=10, calc_on_every_tick=false)

// ─────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────

fast_len      = input.int(20, "Fast EMA Length", minval=1, maxval=500, group="Trend")
slow_len      = input.int(50, "Slow EMA Length", minval=1, maxval=500, group="Trend")

use_htf       = input.bool(false, "Require HTF trend confirmation", group="Trend")
htf_tf        = input.timeframe("240", "Higher timeframe", group="Trend")

adx_len       = input.int(14, "ADX Length", minval=1, maxval=50, group="Filters")
adx_threshold = input.float(20.0, "ADX minimum (trend strength)", minval=0.0, maxval=100.0, step=0.5, group="Filters")
use_vol_filter = input.bool(false, "Require volume > SMA(volume)", group="Filters")
vol_len       = input.int(20, "Volume SMA length", minval=1, maxval=500, group="Filters")

show_emas     = input.bool(true, "Plot EMAs", group="Display")
show_trend_bg = input.bool(true, "Background: trend direction", group="Display")
show_shapes   = input.bool(true, "Plot Buy / Sell markers", group="Display")

col_ema_fast  = input.color(color.new(color.teal, 0), "Fast EMA color", group="Colors")
col_ema_slow  = input.color(color.new(color.orange, 0), "Slow EMA color", group="Colors")
col_bull_bg   = input.color(color.new(color.green, 92), "Bull background", group="Colors")
col_bear_bg   = input.color(color.new(color.red, 92), "Bear background", group="Colors")
col_buy       = input.color(color.new(color.lime, 0), "Buy marker", group="Colors")
col_sell      = input.color(color.new(color.red, 0), "Sell marker", group="Colors")

// ─────────────────────────────────────────────
// PHASE 2 — CORE TREND
// ─────────────────────────────────────────────

ema_fast = ta.ema(close, fast_len)
ema_slow = ta.ema(close, slow_len)

plot(show_emas ? ema_fast : na, "Fast EMA", col_ema_fast, linewidth=2)
plot(show_emas ? ema_slow : na, "Slow EMA", col_ema_slow, linewidth=2)

// ─────────────────────────────────────────────
// PHASE 4 — FILTERS
// ─────────────────────────────────────────────

adx_val = ta.adx(high, low, close, adx_len)
adx_ok  = not na(adx_val) and adx_val > adx_threshold

vol_ma = ta.sma(volume, vol_len)
vol_ok = not use_vol_filter or (not na(volume) and not na(vol_ma) and volume > vol_ma)

htf_bull = request.security(syminfo.tickerid, htf_tf, ta.ema(close, fast_len) > ta.ema(close, slow_len),
     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htf_bear = request.security(syminfo.tickerid, htf_tf, ta.ema(close, fast_len) < ta.ema(close, slow_len),
     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

htf_ok_long  = not use_htf or htf_bull
htf_ok_short = not use_htf or htf_bear

// ─────────────────────────────────────────────
// PHASE 3 — CROSSOVER SIGNALS (edge-triggered)
// ─────────────────────────────────────────────

bull_raw = ta.crossover(ema_fast, ema_slow)
bear_raw = ta.crossunder(ema_fast, ema_slow)

bull_signal = bull_raw and adx_ok and vol_ok and htf_ok_long
bear_signal = bear_raw and adx_ok and vol_ok and htf_ok_short

// Background: optional tint by EMA stack (not only on signal bar)
bgcolor(show_trend_bg and ema_fast > ema_slow ? col_bull_bg : show_trend_bg and ema_fast < ema_slow ? col_bear_bg : na, title="Trend tint")

plotshape(show_shapes and bull_signal, "Buy", shape.triangleup, location.belowbar, col_buy, 0, "Buy", na, true, size.small)
plotshape(show_shapes and bear_signal, "Sell", shape.triangledown, location.abovebar, col_sell, 0, "Sell", na, true, size.small)

// ─────────────────────────────────────────────
// PHASE 5 — ALERTS
// ─────────────────────────────────────────────

alertcondition(bull_signal, "Trend Buy (filtered)", "Bullish EMA crossover with filters OK")
alertcondition(bear_signal, "Trend Sell (filtered)", "Bearish EMA crossover with filters OK")

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 6 — TESTING (manual)
// ═══════════════════════════════════════════════════════════════════════════
// Suggested checks (visual, no built-in optimizer here):
//  1) NQ 15m / 1h — verify crosses match EMA plots; ADX gate suppresses chop.
//  2) ES same TFs — volume filter behaviour (session gaps).
//  3) BTC 1h — HTF confirm off vs on (e.g. HTF = 1D).
//  4) Thin symbol — toggle volume filter off if volume unreliable.
//  5) Compare fast/slow lengths 10/30 vs 20/50 for responsiveness vs noise.
//
// Division safety: this script does not divide by price; ADX/volume paths guard `na`.
